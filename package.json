{
  "name": "xdesk-client",
  "version": "1.0.0",
  "description": "Remote desktop client",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "agent": "node dist/index.js agent",
    "controller": "node dist/index.js controller",
    "package": "pkg dist/index.js --targets node18-win-x64 --output xdesk.exe"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "https-proxy-agent": "^7.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "pkg": "^5.8.0"
  },
  "pkg": {
    "assets": [],
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  }
}
